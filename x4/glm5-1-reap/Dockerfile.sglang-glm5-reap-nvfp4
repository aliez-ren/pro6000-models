FROM nvidia/cuda:12.9.1-cudnn-devel-ubuntu24.04

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    HF_HOME=/root/.cache/huggingface \
    VENV=/opt/venv \
    PIP_NO_CACHE_DIR=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    git \
    libnuma1 \
    ninja-build \
    python3 \
    python3-dev \
    python3-pip \
    python3-venv \
    && rm -rf /var/lib/apt/lists/*

RUN python3 -m venv "${VENV}"

ENV PATH="${VENV}/bin:${PATH}"

RUN pip install --upgrade pip setuptools wheel && \
    pip install "sglang[all]==0.5.10.post1" flashinfer-python==0.6.7.post3 flashinfer-cubin==0.6.7.post3 && \
    python -c "import flashinfer, sglang, torch; print(sglang.__version__, torch.__version__, flashinfer.__version__)"

RUN python - <<'PY'
from pathlib import Path
import re

path = Path("/opt/venv/lib/python3.12/site-packages/sglang/srt/configs/model_config.py")
text = path.read_text()
patched, count = re.subn(
    r'^\s*["\']GlmMoeDsaForCausalLM["\'],?\s*$\n?',
    "",
    text,
    flags=re.MULTILINE,
)
if count == 0 and "GlmMoeDsaForCausalLM" in text:
    patched = patched.replace('"GlmMoeDsaForCausalLM"', "")
    if patched == text:
        raise SystemExit(f"Could not patch {path}")
    count = 1

path.write_text(patched)

print(f"Patched {path} ({count} replacements)")
PY

COPY docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh

RUN chmod +x /usr/local/bin/docker-entrypoint.sh

EXPOSE 8000

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
