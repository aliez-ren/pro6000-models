FROM voipmonitor/sglang:cu130

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    HF_HOME=/root/.cache/huggingface \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# voipmonitor/sglang:cu130 already ships:
#   - PyTorch 2.11+cu130, CUDA 13.0.1, cuDNN, NCCL cu13
#   - FlashInfer (built from source for sm_120a)
#   - SGLang fork (voipmonitor/blackwell-cu130) with PRs pre-merged
#   - b12x NVFP4 MoE/GEMM backend
#   - nvidia-cutlass-dsl[cu13] with libs-cu13 fix for SM120 _mma.block_scale
#   - sm120 runtime patches (flashinfer assert / triton smem / pcie allreduce / IndexCache / ...)
#
# Add GlmMoeDsaForCausalLM to is_deepseek_nsa()'s architecture allow-list so that
# DeepseekV2AttentionMLA's indexer block (which initializes skip_topk / next_skip_topk
# from index_topk_pattern) actually runs for GLM-5.1-*-REAP-NVFP4. Without this,
# CUDA graph capture crashes in forward_mla.py with:
#   AttributeError: 'DeepseekV2AttentionMLA' object has no attribute 'next_skip_topk'

RUN python - <<'PY'
from pathlib import Path
import sglang.srt.configs.model_config as m

path = Path(m.__file__)
text = path.read_text()

# Anchor is the *first* (NSA-list) occurrence of PixtralForConditionalGeneration,
# inside is_deepseek_nsa(). The architecture name also appears in an unrelated
# MLA-arch list later in the file, so a plain "GlmMoeDsaForCausalLM in text"
# check would give false positives — count occurrences of the anchor block tag.
nsa_block_marker = '"DeepseekV32ForCausalLM",\n            "DeepseekV3ForCausalLMNextN",'
if nsa_block_marker not in text:
    raise SystemExit(
        f"NSA architecture list marker not found in {path}; "
        "voipmonitor's fork may have changed structure."
    )

nsa_idx = text.index(nsa_block_marker)
list_end = text.index("]", nsa_idx)
nsa_block = text[nsa_idx:list_end]
if "GlmMoeDsaForCausalLM" in nsa_block:
    print(f"is_deepseek_nsa() already includes GlmMoeDsaForCausalLM; skipping")
else:
    insertion = '"PixtralForConditionalGeneration",'
    pixtral_idx = text.index(insertion, nsa_idx)
    patched = (
        text[: pixtral_idx + len(insertion)]
        + '\n            "GlmMoeDsaForCausalLM",'
        + text[pixtral_idx + len(insertion):]
    )
    path.write_text(patched)
    print(f"Added GlmMoeDsaForCausalLM to is_deepseek_nsa() in {path}")
PY

COPY docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh

RUN chmod +x /usr/local/bin/docker-entrypoint.sh

EXPOSE 8000

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
